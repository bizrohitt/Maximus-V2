{
  "name": "maximus-frontend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "predev": "node -e \"const fs=require('fs');try{fs.rmSync('.next',{recursive:true,force:true})}catch{}\"",
    "dev": "next dev --turbo",
    "dev:fix": "powershell -ExecutionPolicy Bypass -File scripts/start-dev.ps1",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "generate:favicon": "node scripts/generate-favicon.js",
    "fix": "powershell -ExecutionPolicy Bypass -File scripts/fix-dev.ps1",
    "clean": "Remove-Item -Recurse -Force .next -ErrorAction SilentlyContinue"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "lucide-react": "^0.379.0",
    "next": "^14.2.35",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tailwind-merge": "^2.3.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.19",
    "eslint": "^8",
    "eslint-config-next": "^14.2.35",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
